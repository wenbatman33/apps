{
  "id": "fantasy",
  "name": "Dragon's Realm",
  "version": "1.0.0",
  "description": "Fantasy medieval theme - swap-in example showing theme portability",

  "colors": {
    "background": "#050a05",
    "reelBg": "#070d07",
    "reelBorder": "#4a8a2a",
    "reelBorderGlow": "#66cc44",
    "panelBg": "#060e06",
    "panelBorder": "#3a6a2a",
