        if (!infoRes.ok) {
            if (infoRes.status === 404) throw new Error("\u627E\u4E0D\u5230\u6B64\u623F\u9593\uFF0C\u8ACB\u78BA\u8A8D\u9080\u8ACB\u78BC");
