{
  "name": "poker-game-mp",
  "version": "1.0.0",
  "description": "多人德州撲克 - Boardgame.io + PixiJS",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:lobby": "parcel build client/lobby.js --dist-dir public/dist/lobby --no-scope-hoist",
    "build:game": "parcel build client/game-client.js --dist-dir public/dist/game --no-scope-hoist",
    "build:client": "npm run build:lobby && npm run build:game",
    "build": "npm run build:client"
  },
  "dependencies": {
    "boardgame.io": "0.50.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "koa-static": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "parcel": "^2.11.0",
    "process": "^0.11.10"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
